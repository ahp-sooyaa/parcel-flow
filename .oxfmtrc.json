{
  "ignorePatterns": [
    ".agent/**",
    ".agents/**",
    "openspec/**",
    ".next/**",
    "node_modules/**",
    "package.json"
  ],
  "sortImports": {
    "newlinesBetween": false,
    "groups": [
      ["value-builtin", "value-external"],
      ["value-internal", "value-parent", "value-sibling", "value-index"],
      { "newlinesBetween": true },
      "type-import",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./src/app/globals.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": true
  }
}
